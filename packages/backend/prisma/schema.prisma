generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProgressStatus {
  NOT_SEEN
  SEEN
  CAUGHT
}

enum LearnMethod {
  LEVEL
  TM
  EGG
  TUTOR
}

enum UserRole {
  USER
  ADMIN
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IntegrationStatus {
  ACTIVE
  INACTIVE
  ERROR
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  username     String         @unique
  passwordHash String
  role         UserRole       @default(USER)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  progress     UserProgress[]
  scanHistory  ScanHistory[]
  sessions     Session[]
  tickets      SupportTicket[]
  logs         SystemLog[]

  @@map("users")
}

model Integration {
  id          String            @id @default(cuid())
  key         String            @unique
  name        String
  description String?
  baseUrl     String?
  apiKey      String?
  status      IntegrationStatus @default(INACTIVE)
  lastChecked DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("integrations")
}

model SupportTicket {
  id          String         @id @default(cuid())
  userId      String
  subject     String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  response    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("support_tickets")
}

model SystemLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  detail    String?
  level     String   @default("INFO")
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("system_logs")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Pokemon {
  id              String         @id @default(cuid())
  nationalDexNumber Int          @unique
  name            String
  types           String[]
  height          Float
  weight          Float
  description     String
  habitat         String?
  category        String?
  abilities       String[]
  baseStats       Json
  spriteUrl       String?
  artworkUrl      String?
  generation      Int
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  evolutions      Evolution[]    @relation("PokemonEvolutions")
  evolvesFrom     Evolution[]    @relation("EvolvesFrom")
  moves           Move[]
  progress        UserProgress[]
  scanHistory     ScanHistory[]

  @@map("pokemon")
}

model Evolution {
  id           String  @id @default(cuid())
  pokemonId    String
  evolvesToId  String
  condition    String?
  conditionDetail String?

  pokemon   Pokemon @relation("PokemonEvolutions", fields: [pokemonId], references: [id])
  evolvesTo Pokemon @relation("EvolvesFrom", fields: [evolvesToId], references: [id])

  @@map("evolutions")
}

model Move {
  id          String      @id @default(cuid())
  pokemonId   String
  name        String
  type        String
  power       Int?
  accuracy    Int?
  pp          Int?
  description String?
  learnMethod LearnMethod
  level       Int?

  pokemon Pokemon @relation(fields: [pokemonId], references: [id], onDelete: Cascade)

  @@map("moves")
}

model UserProgress {
  id        String         @id @default(cuid())
  userId    String
  pokemonId String
  status    ProgressStatus @default(NOT_SEEN)
  scannedAt DateTime?
  photoUrl  String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  pokemon Pokemon @relation(fields: [pokemonId], references: [id], onDelete: Cascade)

  @@unique([userId, pokemonId])
  @@map("user_progress")
}

model ScanHistory {
  id         String   @id @default(cuid())
  userId     String
  pokemonId  String
  confidence Float
  imageUrl   String?
  createdAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  pokemon Pokemon @relation(fields: [pokemonId], references: [id], onDelete: Cascade)

  @@map("scan_history")
}
