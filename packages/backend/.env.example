# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:123Password@localhost:5432/pokedex

# JWT — generate a secure random key for production:
#   openssl rand -hex 32
JWT_SECRET=dev-secret-change-in-production

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# PokeAPI (optional override)
# POKEAPI_BASE_URL=https://pokeapi.co/api/v2

# Redis (optional — falls back to in-memory cache if not set)
# REDIS_URL=redis://localhost:6379

# Gemini API key (required for vision & chat features)
# GEMINI_API_KEY=AIzaSy...

# SMTP (optional — needed for password reset emails)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@pokedex.com
